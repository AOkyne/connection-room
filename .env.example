# The Connection Room - Environment Variables
#
# This file lists only variables actually read by the current codebase
# (verified via a repo-wide `grep -R "process.env"` sweep; see README.md's
# "Environment variables" section for the required/optional breakdown).
# Do not put real secret values in this file -- names and, at most,
# non-secret defaults only.

# App Configuration
NEXT_PUBLIC_APP_URL=https://community.trevorjamesla.com

# Supabase -- required for the app to run as anything other than an
# unauthenticated demo shell (lib/app-mode.ts infers demo mode purely from
# these being unset; see ARCHITECTURE.md's "Demo and preview architecture").
# Get these values from your Supabase project dashboard: https://app.supabase.com/
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Demo mode admin secret key. Client-exposed (NEXT_PUBLIC) by design -- this
# is a low-security, legacy/demo affordance for the admin-secret entry path
# on /auth, not a real access-control mechanism. Falls back to
# "connection2024" in code if unset.
NEXT_PUBLIC_DEMO_ADMIN_SECRET=connection2024

# Cron Jobs
# Secret token for verifying Vercel Cron requests to /api/cron/*.
# Generate a secure random token: openssl rand -hex 32
CRON_SECRET=

# Workshop Ops integration (server-only — never prefix with NEXT_PUBLIC_)
# Used by app/api/webhooks/workshop-ops to authenticate with workshops.trevorjamesla.com
WORKSHOP_API_KEY=

# Space activity notifications (migration 054)
# Shared secret the posts_notify_new_post Postgres trigger sends in its
# Authorization header when it calls app/api/webhooks/new-post-notification.
# Generate a secure random token the same way as CRON_SECRET, then paste
# the SAME value into the migration's notify_new_post() function body
# (Postgres can't read this env var directly).
POST_NOTIFICATION_WEBHOOK_SECRET=

# Outbound email (Nodemailer over SMTP) -- transactional and broadcast email
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# Zoom (server-only) -- Server-to-Server OAuth app, used by admin event
# tooling to create/delete meetings
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# NOTE: earlier versions of this file also listed
# NEXT_PUBLIC_DAILY_COMPANION_LAUNCH_DATE, NEXT_PUBLIC_PLATFORM_TIMEZONE,
# NEXT_PUBLIC_DEMO_MODE_ENABLED, NEXT_PUBLIC_QUIZ_URL,
# NEXT_PUBLIC_CONSULT_URL, NEXT_PUBLIC_COUPLES_CALL_URL, and
# NEXT_PUBLIC_MAIN_WEBSITE. None of these are read anywhere in the current
# codebase -- the Daily Companion launch date is a hardcoded constant in
# lib/data/daily-companion.ts, and the marketing URLs are hardcoded in
# lib/config.ts. Removed here rather than left as dead configuration
# surface; re-add only alongside the code change that actually wires them
# up.
